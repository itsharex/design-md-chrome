{
  "manifest_version": 3,
  "name": "DESIGN.md Style Extractor",
  "description": "Extract page styles and generate DESIGN.md or SKILL.md files from a design blueprint based on the TypeUI configuration.",
  "version": "0.1.0",
  "homepage_url": "https://www.typeui.sh",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "action": {
    "default_title": "DESIGN.md Style Extractor",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
